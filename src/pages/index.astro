---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import { clients, projects, services } from '../data/site';
---
<BaseLayout title="Mekon e Ingenieria S.A.S. | Soluciones industriales" description="Ingenieria, montaje, metalmecanica, infraestructura civil e integridad de activos para operaciones industriales.">
  <section class="hero" style="background-image:url('/images/projects/plant-aerial-hero.jpg')"><div class="shell hero-content"><p class="eyebrow light">Mekon e Ingenieria S.A.S. · Desde 2011</p><h1>Ingenieria que convierte alcance tecnico en ejecucion confiable.</h1><p>Desarrollamos proyectos de diseno, fabricacion, montaje, obra civil e integridad de activos para instalaciones industriales con exigencias reales de seguridad, calidad y continuidad operativa.</p><div class="hero-actions"><a class="button primary" href="/servicios/">Explorar servicios</a><a class="button secondary" href="/contacto/">Solicitar propuesta</a></div><div class="hero-stats"><div><strong>Desde 2011</strong><span>Experiencia en ejecucion industrial</span></div><div><strong>API / ASME / FM</strong><span>Criterio tecnico aplicable</span></div><div><strong>HSEQ</strong><span>Gestion de seguridad y calidad</span></div><div><strong>Colombia y Peru</strong><span>Cobertura de proyectos</span></div></div></div></section>
  <section class="section"><div class="shell split"><div class="split-media"><img src="/images/projects/loading-manifold-wide.jpg" alt="Sistema industrial de transferencia de fluidos" /><div class="info-block"><strong>Alcance integral</strong><span>Ingenieria, suministro, ejecucion y soporte en una misma coordinacion tecnica.</span></div></div><div><p class="eyebrow">Empresa</p><h2>Capacidad para intervenir activos y proyectos industriales.</h2><p class="body-copy">Mekon e Ingenieria S.A.S. atiende requerimientos de los sectores metalmecanico, oil & gas, construccion civil, suministros industriales y servicios especializados. Cada frente se organiza desde la definicion del alcance hasta la entrega de evidencias tecnicas.</p><div class="check-list"><span>Planeacion de obra</span><span>Fabricacion controlada</span><span>Montaje especializado</span><span>Soporte operativo</span></div><a class="text-link" href="/empresa/">Conocer la empresa <span>→</span></a></div></div></section>
  <section class="section mist"><div class="shell"><div class="section-head"><div><p class="eyebrow">Servicios</p><h2>Especialidades para la infraestructura que mantiene una operacion en movimiento.</h2></div><p>Las lineas de servicio se presentan como capacidades independientes, con alcance y aplicaciones claras para facilitar la evaluacion tecnica de cada requerimiento.</p></div><div class="service-grid">{services.map((service) => <ServiceCard service={service} />)}</div></div></section>
  <section class="dark-band"><div class="shell dark-grid"><div><p class="eyebrow light">Integridad de activos</p><h2>Control tecnico sobre corrosion, recubrimientos e informacion de campo.</h2><p>Soluciones orientadas a extender la vida util de la infraestructura metalica, anticipar deterioros y sustentar decisiones de mantenimiento.</p><a class="button secondary" href="/integridad-de-activos/">Ver capacidades de integridad</a></div><div class="tag-grid"><span>Sistemas ICCP</span><span>Anodos galvanicos</span><span>Monitoreo y telemetria</span><span>Inspeccion CIPS/DCVG</span><span>Ultrasonido y diagnostico</span><span>Recubrimientos industriales</span></div></div></section>
  <section class="section"><div class="shell"><div class="section-head"><div><p class="eyebrow">Proyectos</p><h2>Evidencia de ejecucion en campo.</h2></div><p>Una seleccion de frentes que representa el tipo de soluciones que Mekon coordina para instalaciones industriales y de almacenamiento.</p></div><div class="project-grid">{projects.map((project) => <article class="project-card"><img src={project.image} alt={project.title} loading="lazy" /><div><span>{project.category}</span><h3>{project.title}</h3><p>{project.text}</p></div></article>)}</div><a class="text-link" href="/proyectos/">Ver portafolio de proyectos <span>→</span></a></div></section>
  <section class="section mist"><div class="shell"><p class="eyebrow">Referencias</p><h2>Organizaciones que han confiado en nuestra capacidad de ejecucion.</h2><div class="logo-grid">{clients.map((client) => <div class:list={['client-logo', client]}><img src={`/images/clients/${client}.png`} alt={client.replaceAll('-', ' ')} loading="lazy" /></div>)}</div><a class="text-link" href="/referencias/">Ver referencias <span>→</span></a></div></section>
  <section class="cta-band"><div class="shell"><div><p class="eyebrow light">Contacto comercial</p><h2>Conversemos sobre el alcance tecnico de su proximo proyecto.</h2></div><a class="button" href="/contacto/">Contactar a Mekon</a></div></section>
</BaseLayout>
