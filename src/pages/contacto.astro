---
import BaseLayout from '../layouts/BaseLayout.astro';
import { locations, services, site } from '../data/site';
---
<BaseLayout title="Contacto | Mekon e Ingenieria S.A.S." description="Contacte a Mekon e Ingenieria S.A.S. para requerimientos tecnicos, proyectos y servicios industriales.">
  <section class="page-hero"><div class="shell"><p class="breadcrumb">Inicio / Contacto</p><p class="eyebrow">Contacto comercial</p><h1>Cuéntenos las condiciones de su requerimiento tecnico.</h1><p>Comparta la informacion inicial disponible. El equipo revisara el alcance para orientar la respuesta tecnica y comercial.</p></div></section>
  <section class="section mist"><div class="shell contact-layout"><form class="contact-form" data-contact-form action={`mailto:${site.commercialEmail}`} method="post" enctype="text/plain"><div class="form-head"><h2>Solicitud de contacto</h2><p>Los campos marcados con * son obligatorios.</p></div><div class="form-grid"><label>Nombre completo *<input name="nombre" autocomplete="name" required /></label><label>Empresa *<input name="empresa" autocomplete="organization" required /></label><label>Correo electronico *<input name="correo" type="email" autocomplete="email" required /></label><label>Telefono *<input name="telefono" type="tel" autocomplete="tel" required /></label><label>Ciudad / ubicacion<input name="ciudad" /></label><label>Linea de servicio *<select name="servicio" required><option value="">Seleccione una opcion</option>{services.map((service) => <option>{service.title}</option>)}</select></label><label class="full">Descripcion del requerimiento *<textarea name="mensaje" placeholder="Indique alcance preliminar, condiciones operativas y tiempos estimados." required></textarea></label></div><button class="button primary" type="submit">Enviar solicitud</button></form><aside class="contact-side"><p class="eyebrow light">Atencion comercial</p><h2>Canales directos</h2><p>Para requerimientos prioritarios o informacion complementaria, comuniquese con nuestro equipo.</p><a href={`mailto:${site.commercialEmail}`}><small>Correo comercial</small>{site.commercialEmail}</a><a href={`mailto:${site.managementEmail}`}><small>Gerencia</small>{site.managementEmail}</a><a href={site.phoneHref}><small>Telefono comercial</small>{site.phone}</a><a class="button primary" href={site.whatsapp} target="_blank" rel="noopener">Iniciar conversacion por WhatsApp</a></aside></div></section>
  <section class="section"><div class="shell"><p class="eyebrow">Sedes y cobertura</p><div class="logo-grid">{locations.map((location) => <div style="height:auto"><strong>{location.city}</strong><p class="body-copy">{location.address}</p>{location.phone && <a class="text-link" href={location.href}>{location.phone}</a>}</div>)}</div></div></section>
  <script is:inline define:vars={{ commercialEmail: site.commercialEmail }}>
    document.querySelector('[data-contact-form]')?.addEventListener('submit', (event) => { event.preventDefault(); const form = event.currentTarget; const data = new FormData(form); const subject = `Solicitud web - ${data.get('empresa')} - ${data.get('servicio')}`; const body = ['Nombre: ' + data.get('nombre'),'Empresa: ' + data.get('empresa'),'Correo: ' + data.get('correo'),'Telefono: ' + data.get('telefono'),'Ciudad / ubicacion: ' + data.get('ciudad'),'Linea de servicio: ' + data.get('servicio'),'','Descripcion del requerimiento:', data.get('mensaje')].join('\n'); window.location.href = `mailto:${commercialEmail}?subject=${encodeURIComponent(subject)}&body=${encodeURIComponent(body)}`; });
  </script>
</BaseLayout>
