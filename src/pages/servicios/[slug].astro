---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services } from '../../data/site';
export function getStaticPaths() { return services.map((service) => ({ params: { slug: service.slug }, props: { service } })); }
const { service } = Astro.props;
---
<BaseLayout title={`${service.title} | Mekon e Ingenieria S.A.S.`} description={service.summary} image={service.image}>
  <section class="page-hero"><div class="shell"><p class="breadcrumb"><a href="/">Inicio</a> / <a href="/servicios/">Servicios</a> / {service.title}</p><p class="eyebrow">Linea de servicio</p><h1>{service.title}</h1><p>{service.summary}</p></div></section>
  <section class="section"><div class="shell detail-layout"><div><img src={service.image} alt={service.title} style="width:100%;height:420px;object-fit:cover" /><p class="eyebrow" style="margin-top:34px">Alcance tecnico</p><h2>Capacidad orientada a condiciones reales de proyecto.</h2><p class="body-copy">Mekon estructura esta linea de servicio desde la revision de alcance, definicion de recursos, programacion y coordinacion de actividades de campo. El objetivo es entregar una solucion ejecutable, trazable y compatible con la operacion del activo.</p><ul class="service-list">{service.items.map((item) => <li>{item}</li>)}</ul></div><aside class="aside-card"><p class="eyebrow">Contacto</p><h2>Necesita evaluar este servicio?</h2><p>Comparta la informacion disponible del activo, la ubicacion y las condiciones de operacion. El equipo comercial orientara el siguiente paso.</p><a class="button primary" href="/contacto/">Solicitar propuesta</a><a class="text-link" href="/servicios/">Volver a servicios <span>→</span></a></aside></div></section>
</BaseLayout>
