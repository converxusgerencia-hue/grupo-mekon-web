---
import { services } from '../data/site';
type Service = (typeof services)[number];
const { service } = Astro.props as { service: Service };
---
<article class="service-card"><a href={`/servicios/${service.slug}/`} class="card-image"><img src={service.image} alt={service.title} loading="lazy" /></a><div><span class="index">{String(services.findIndex((item) => item.slug === service.slug) + 1).padStart(2, '0')}</span><h3><a href={`/servicios/${service.slug}/`}>{service.title}</a></h3><p>{service.short}</p><a class="text-link" href={`/servicios/${service.slug}/`}>Ver servicio <span>→</span></a></div></article>
