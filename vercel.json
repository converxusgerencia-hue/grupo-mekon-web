{
  "framework": "astro",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    { "source": "/inicio", "destination": "/", "permanent": true },
    { "source": "/quienes-somos", "destination": "/empresa/", "permanent": true },
    { "source": "/servicios", "destination": "/servicios/", "permanent": true },
    { "source": "/referencias", "destination": "/referencias/", "permanent": true },
    { "source": "/contacto", "destination": "/contacto/", "permanent": true }
  ]
}
